name: Parser Validation

on:

  workflow_dispatch:

  schedule:
    - cron: "0 */6 * * *"

jobs:

  validate:

    runs-on: ubuntu-latest

    steps:

      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5

        with:
          python-version: "3.11"

      - run: pip install -r requirements.txt

      - run: python tools/validate_all.py

      - run: python tools/stats.py
